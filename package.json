  "scripts": {
    "dev": "concurrently \"next dev\" \"npx localtunnel --port 3000\"",
    "share": "npx localtunnel --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier --check .",
